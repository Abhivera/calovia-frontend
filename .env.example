# =============================================================================
# Calovia Expo frontend — environment template
# =============================================================================
# 1. Copy to `.env` in calovia-frontend/
# 2. Set Firebase + API values (REQUIRED for sign-in)
# 3. Run: npm install && npm run web  →  http://localhost:8081
#
# For Vercel: add the same EXPO_PUBLIC_* variables in Project Settings → Environment Variables
# =============================================================================

EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
