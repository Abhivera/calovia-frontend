# =============================================================================
# Calovia frontend — environment template
# =============================================================================
# 1. Copy this file to `.env` in the same directory (calovia-frontend/).
# 2. Fill in Firebase values (REQUIRED for sign-in / sign-up).
# 3. Start backend Postgres + API (see calovia-backend/.env.example).
# 4. Run: `npm install` then `npm run dev`  →  http://localhost:5173
#
# Only variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Calovia API (REQUIRED)
# -----------------------------------------------------------------------------
# Must match the backend base URL including `/api/v1`
VITE_API_BASE_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Firebase — Web app (REQUIRED)
# -----------------------------------------------------------------------------
# Firebase Console → Project settings → Your apps → Web app → SDK config
# Enable sign-in: Authentication → Sign-in method → Google + Email/Password
# Use the same project as calovia-backend FIREBASE_PROJECT_ID
#
# Example shapes (replace with your project values):
#   VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
