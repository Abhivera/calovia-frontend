{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": false,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "strict": false,
        "noImplicitAny": false,
        "noImplicitThis": false
    },
    "include": [
        "src"
    ]
}